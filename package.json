{
  "name": "match3-game",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Match-3 game built with PixiJS 8, TypeScript, Vite and GSAP",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "gsap": "^3.12.5",
    "pixi.js": "^8.6.6"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "typescript": "^5.6.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
